---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Ivo Vinklárek | Personal Academic Website',
	description = 'Personal academic website',
} = Astro.props;

const sectionLinks = [
	{ href: '#about', label: 'About' },
	{ href: '#research', label: 'Research' },
	{ href: '#projects', label: 'Projects' },
	{ href: '#blog', label: 'Blog' },
	{ href: '#cv', label: 'CV' },
	{ href: '#links', label: 'Links' },
	{ href: '#contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site-shell">
			<header class="mobile-profile" aria-label="Site profile">
				<div class="mobile-profile-row">
					<div class="profile-photo" aria-hidden="true">IV</div>
					<div>
						<p class="profile-name">Ivo Vinklárek</p>
						<p class="profile-description">Personal academic website</p>
					</div>
				</div>
				<nav class="section-nav mobile-nav" aria-label="Homepage sections">
					<ul>
						{
							sectionLinks.map((link) => (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							))
						}
					</ul>
				</nav>
			</header>

			<div class="content-column">
				<slot />
			</div>

			<aside class="site-sidebar" aria-label="Profile and section navigation">
				<div class="profile-photo" aria-hidden="true">IV</div>
				<p class="profile-name">Ivo Vinklárek</p>
				<p class="profile-description">Personal academic website</p>
				<nav class="section-nav" aria-label="Homepage sections">
					<ul>
						{
							sectionLinks.map((link) => (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							))
						}
					</ul>
				</nav>
			</aside>
		</div>

		<script>
			const sidebarLinks = Array.from(
				document.querySelectorAll('.site-sidebar .section-nav a[href^="#"]'),
			);
			const linkedSections = sidebarLinks
				.map((link) => {
					const href = link.getAttribute('href');
					return href ? document.querySelector(href) : null;
				})
				.filter(Boolean);

			const updateActiveSection = () => {
				const readingLine = window.innerHeight * 0.24;
				let activeSection = linkedSections[0];

				for (const section of linkedSections) {
					if (section.getBoundingClientRect().top <= readingLine) {
						activeSection = section;
					}
				}

				for (const link of sidebarLinks) {
					const isActive = link.getAttribute('href') === `#${activeSection?.id}`;
					link.classList.toggle('is-active', isActive);
					if (isActive) {
						link.setAttribute('aria-current', 'location');
					} else {
						link.removeAttribute('aria-current');
					}
				}
			};

			updateActiveSection();
			window.addEventListener('scroll', updateActiveSection, { passive: true });
			window.addEventListener('resize', updateActiveSection);
		</script>
	</body>
</html>

<style is:global>
	:root {
		--background: #ffffff;
		--surface: #f6f6f6;
		--text: #171717;
		--muted: #6a6a6a;
		--border: #dddddd;
		--accent: #404040;
		--surface-strong: #eeeeee;
		--content-width: 700px;
		--sidebar-width: 200px;
		--sidebar-gap: 2.5rem;
		--sidebar-top: 16vh;
		--page-padding: 1.5rem;

		color: var(--text);
		background: var(--background);
		font-family:
			ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
			sans-serif;
		font-size: 16px;
		line-height: 1.7;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--background);
	}

	body {
		margin: 0;
		min-width: 320px;
		background: var(--background);
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
	}

	a {
		color: var(--text);
		text-decoration-thickness: 1px;
		text-underline-offset: 0.18em;
	}

	a:hover {
		color: var(--accent);
	}

	p {
		margin: 0 0 1rem;
	}

	.site-shell {
		display: grid;
		grid-template-columns:
			minmax(calc(var(--sidebar-width) + var(--sidebar-gap)), 1fr)
			minmax(0, var(--content-width))
			minmax(calc(var(--sidebar-width) + var(--sidebar-gap)), 1fr);
		width: 100%;
		margin: 0;
		padding: 4rem var(--page-padding) 5rem;
		align-items: start;
	}

	.content-column {
		grid-column: 2;
		min-width: 0;
		padding-top: clamp(0rem, calc(var(--sidebar-top) - 4rem), 7rem);
	}

	.site-main {
		max-width: var(--content-width);
		padding-bottom: 60vh;
	}

	.site-section {
		padding: 0;
		margin: 0 0 3rem;
		scroll-margin-top: 1.5rem;
	}

	.site-section:last-child {
		margin-bottom: 0;
	}

	.site-section h1,
	.site-section h2 {
		margin: 0 0 0.65rem;
		color: var(--text);
		font-weight: 620;
		line-height: 1.2;
		letter-spacing: 0;
	}

	.site-section h1 {
		font-size: 1.85rem;
	}

	.site-section h2 {
		font-size: 1.15rem;
	}

	.site-section p {
		max-width: 64ch;
		color: #343434;
	}

	.site-sidebar {
		grid-column: 3;
		justify-self: start;
		position: sticky;
		top: var(--sidebar-top);
		width: var(--sidebar-width);
		margin-left: var(--sidebar-gap);
		padding: 1rem 1rem 1.1rem;
		border-radius: 0.4rem;
		background: var(--surface);
	}

	.mobile-profile {
		display: none;
	}

	.profile-photo {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 6.5rem;
		aspect-ratio: 1;
		margin: 0 0 1rem;
		border-radius: 50%;
		background: var(--surface-strong);
		box-shadow: inset 0 0 0 1px var(--border);
		color: var(--muted);
		font-family: ui-sans-serif, system-ui, sans-serif;
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: 0;
	}

	.profile-name {
		margin: 0 0 0.15rem;
		color: var(--text);
		font-size: 0.98rem;
		font-weight: 550;
		line-height: 1.25;
	}

	.profile-description {
		margin: 0 0 1.45rem;
		color: var(--muted);
		font-size: 0.88rem;
		line-height: 1.45;
	}

	.section-nav {
		border-left: 1px solid var(--border);
		padding-left: 0.9rem;
	}

	.section-nav ul {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.section-nav a {
		display: inline-block;
		position: relative;
		color: var(--muted);
		font-size: 0.9rem;
		line-height: 1.45;
		text-decoration: none;
	}

	.section-nav a:hover {
		color: var(--accent);
		text-decoration: underline;
	}

	.site-sidebar .section-nav a::before {
		position: absolute;
		top: 0.63em;
		left: -1.08rem;
		width: 0.35rem;
		height: 0.35rem;
		border-radius: 50%;
		background: transparent;
		content: '';
	}

	.site-sidebar .section-nav a.is-active,
	.site-sidebar .section-nav a[aria-current='location'] {
		color: var(--accent);
		font-weight: 650;
	}

	.site-sidebar .section-nav a.is-active::before,
	.site-sidebar .section-nav a[aria-current='location']::before {
		background: var(--accent);
	}

	@media (max-width: 760px) {
		:root {
			font-size: 16px;
		}

		.site-shell {
			display: block;
			padding: 1.5rem 1.15rem 3rem;
		}

		.site-sidebar {
			display: none;
		}

		.content-column {
			padding-top: 0;
		}

		.mobile-profile {
			display: block;
			padding-bottom: 1.35rem;
			margin-bottom: 2.25rem;
			border-bottom: 1px solid var(--border);
		}

		.mobile-profile-row {
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.mobile-profile .profile-photo {
			flex: 0 0 4rem;
			width: 4rem;
			margin: 0;
			font-size: 0.86rem;
		}

		.mobile-profile .profile-name {
			font-size: 1rem;
			font-weight: 600;
		}

		.mobile-profile .profile-description {
			font-size: 0.88rem;
			margin-bottom: 0;
		}

		.mobile-nav {
			margin-top: 1.1rem;
			padding-left: 0;
			border-left: 0;
		}

		.mobile-nav ul {
			flex-flow: row wrap;
			gap: 0.35rem 0.9rem;
		}

		.mobile-nav a {
			color: var(--text);
			font-size: 0.9rem;
		}

		.site-main {
			max-width: none;
			padding-bottom: 1rem;
		}

		.site-section {
			margin-bottom: 2.65rem;
		}

		.site-section h1 {
			font-size: 1.75rem;
		}
	}

	@media (min-width: 761px) and (max-width: 1228px) {
		.site-shell {
			grid-template-columns: minmax(0, var(--content-width)) var(--sidebar-width);
			column-gap: var(--sidebar-gap);
			width: min(
				100%,
				calc(
					var(--content-width) + var(--sidebar-gap) + var(--sidebar-width) +
						3rem
				)
			);
			margin: 0 auto;
		}

		.content-column,
		.site-sidebar {
			grid-column: auto;
		}

		.site-sidebar {
			margin-left: 0;
		}
	}
</style>
