---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ivo Vinklárek | Personal Website">
  <main>
    <section id="home">
      <h1>Ivo Vinklárek</h1>
      <p>
        Personal academic website focused on research, scientific growth,
        personal reflections, and long-term academic development.
      </p>
    </section>

    <section id="about">
      <h2>About</h2>
      <p>
        A short introduction about who I am, my academic path, and the ideas
        that shape my personal and scientific development.
      </p>
    </section>

    <section id="research">
      <h2>Research</h2>
      <p>
        Research projects, scientific interests, publications, and ongoing ideas.
      </p>
    </section>

    <section id="cv">
      <h2>CV</h2>
      <p>
        Education, academic experience, skills, publications, and professional record.
      </p>
    </section>

    <section id="blog">
      <h2>Blog</h2>
      <p>
        Notes and reflections on research, conferences, cycling, hiking, travel,
        and other personal activities.
      </p>
    </section>

    <section id="links">
      <h2>Links</h2>
      <p>
        Interesting websites, resources, and eventually an automatic list of GitHub repositories.
      </p>
    </section>

    <section id="contact">
      <h2>Contact</h2>
      <p>
        Contact information will be added here later.
      </p>
    </section>
  </main>
</Layout>
