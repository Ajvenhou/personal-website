---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Ivo Vinklárek | Personal Academic Website',
	description = 'Personal academic website',
} = Astro.props;

const sectionLinks = [
	{ href: '#about', label: 'About' },
	{ href: '#research', label: 'Research' },
	{ href: '#projects', label: 'Projects' },
	{ href: '#blog', label: 'Blog' },
	{ href: '#cv', label: 'CV' },
	{ href: '#links', label: 'Links' },
	{ href: '#contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site-shell">
			<header class="mobile-profile" aria-label="Site profile">
				<div class="mobile-profile-row">
					<div class="profile-photo" aria-hidden="true">IV</div>
					<div>
						<p class="profile-name">Ivo Vinklárek</p>
						<p class="profile-description">Personal academic website</p>
					</div>
				</div>
				<nav class="section-nav mobile-nav" aria-label="Homepage sections">
					<ul>
						{
							sectionLinks.map((link) => (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							))
						}
					</ul>
				</nav>
			</header>

			<div class="content-column">
				<slot />
			</div>

			<aside class="site-sidebar" aria-label="Profile and section navigation">
				<div class="profile-photo" aria-hidden="true">IV</div>
				<p class="profile-name">Ivo Vinklárek</p>
				<p class="profile-description">Personal academic website</p>
				<nav class="section-nav" aria-label="Homepage sections">
					<ul>
						{
							sectionLinks.map((link) => (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							))
						}
					</ul>
				</nav>
			</aside>
		</div>
	</body>
</html>

<style is:global>
	:root {
		color: #222;
		background: #f8f8f8;
		font-family: Georgia, 'Times New Roman', Times, serif;
		font-size: 17px;
		line-height: 1.65;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: #f8f8f8;
	}

	body {
		margin: 0;
		min-width: 320px;
		background: #f8f8f8;
	}

	a {
		color: #244f6d;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.18em;
	}

	a:hover {
		color: #16344a;
	}

	p {
		margin: 0 0 1rem;
	}

	.site-shell {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 240px;
		gap: 4rem;
		width: min(100%, 1080px);
		margin: 0 auto;
		padding: 3rem 1.5rem 4rem;
		align-items: start;
	}

	.content-column {
		min-width: 0;
	}

	.site-main {
		max-width: 720px;
	}

	.site-section {
		padding: 0 0 2.75rem;
		margin: 0 0 2.75rem;
		border-bottom: 1px solid #d8d8d8;
		scroll-margin-top: 1.5rem;
	}

	.site-section:last-child {
		margin-bottom: 0;
		border-bottom: 0;
	}

	.site-section h1,
	.site-section h2 {
		margin: 0 0 0.65rem;
		color: #111;
		font-weight: 600;
		line-height: 1.2;
		letter-spacing: 0;
	}

	.site-section h1 {
		font-size: 2.2rem;
	}

	.site-section h2 {
		font-size: 1.35rem;
	}

	.site-section p {
		max-width: 66ch;
		color: #333;
	}

	.site-sidebar {
		position: sticky;
		top: 3rem;
		padding-left: 1.5rem;
		border-left: 1px solid #d8d8d8;
	}

	.mobile-profile {
		display: none;
	}

	.profile-photo {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 8rem;
		aspect-ratio: 1;
		margin-bottom: 1.25rem;
		border: 1px solid #c8c8c8;
		background: #ececec;
		color: #555;
		font-family: ui-sans-serif, system-ui, sans-serif;
		font-size: 1.5rem;
		letter-spacing: 0;
	}

	.profile-name {
		margin: 0 0 0.2rem;
		color: #111;
		font-size: 1.2rem;
		font-weight: 600;
		line-height: 1.25;
	}

	.profile-description {
		margin: 0 0 1.35rem;
		color: #555;
		font-size: 0.95rem;
		line-height: 1.45;
	}

	.section-nav ul {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.section-nav a {
		display: inline-block;
		color: #244f6d;
		font-size: 0.98rem;
		text-decoration: none;
	}

	.section-nav a:hover {
		text-decoration: underline;
	}

	@media (max-width: 760px) {
		:root {
			font-size: 16px;
		}

		.site-shell {
			display: block;
			padding: 1.5rem 1.1rem 3rem;
		}

		.site-sidebar {
			display: none;
		}

		.mobile-profile {
			display: block;
			padding-bottom: 1.4rem;
			margin-bottom: 2.25rem;
			border-bottom: 1px solid #d8d8d8;
		}

		.mobile-profile-row {
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.mobile-profile .profile-photo {
			flex: 0 0 4.5rem;
			width: 4.5rem;
			margin: 0;
			font-size: 1rem;
		}

		.mobile-profile .profile-description {
			margin-bottom: 0;
		}

		.mobile-nav {
			margin-top: 1.1rem;
		}

		.mobile-nav ul {
			flex-flow: row wrap;
			gap: 0.4rem 1rem;
		}

		.site-main {
			max-width: none;
		}

		.site-section {
			padding-bottom: 2.25rem;
			margin-bottom: 2.25rem;
		}

		.site-section h1 {
			font-size: 1.85rem;
		}
	}
</style>
